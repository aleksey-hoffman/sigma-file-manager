{
  "name": "sigma-file-manager",
  "version": "2.0.0-beta.2",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.1"
  },
  "volta": {
    "node": "22.13.1"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test": "npm run test:unit:run",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "build-only": "vite build",
    "check": "run-p type-check lint:check test:unit:run",
    "type-check": "vue-tsc --build",
    "lint:eslint": "eslint . --fix",
    "lint:stylelint": "stylelint \"src/**/*.{css,vue}\" --fix",
    "lint:eslint:check": "eslint . --max-warnings 0",
    "lint:stylelint:check": "stylelint \"src/**/*.{css,vue}\" --max-warnings 0",
    "lint:check": "run-s lint:*:check",
    "lint": "run-s lint:eslint lint:stylelint",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:dev:webkit-igpu": "env WEBKIT_DISABLE_COMPOSITING_MODE=1 npm run tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:linux": "NO_STRIP=true tauri build",
    "tauri:gen-icons": "tauri icon ./src/assets/icons/logo-1024x1024.png",
    "tauri:cargo-update": "cd ./src-tauri && cargo update",
    "tauri:cargo-build": "cd ./src-tauri && cargo build",
    "sync-i18n": "npx tsx ./scripts/sync-i18n.js",
    "sync-license": "npx tsx ./scripts/sync-license.js"
  },
  "dependencies": {
    "@crabnebula/tauri-plugin-drag": "^2.1.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "dayjs": "^1.11.20",
    "dompurify": "^3.3.3",
    "lodash.clonedeep": "^4.5.0",
    "@lucide/vue": "^1.0.0",
    "marked": "^17.0.5",
    "minimatch": "^10.2.4",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "reka-ui": "^2.9.2",
    "semver": "^7.7.4",
    "tauri-plugin-system-fonts-api": "^2.0.2",
    "v-wave": "^3.0.4",
    "vaul-vue": "^0.4.1",
    "vue": "^3.5.31",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4",
    "vue-sonner": "^2.0.9",
    "vue3-smooth-dnd": "^0.0.6"
  },
  "devDependencies": {
    "@intlify/eslint-plugin-vue-i18n": "^4.3.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tauri-apps/cli": "^2.10.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^28.0.1",
    "@types/lodash.clonedeep": "^4.5.9",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/eslint-plugin": "^1.6.13",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.39.4",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-vue": "~10.8.0",
    "jsdom": "^29.0.1",
    "npm-run-all2": "^8.0.4",
    "readdirp": "^5.0.0",
    "stylelint": "^17.6.0",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-idiomatic-order": "^10.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-selector-bem-pattern": "^4.0.1",
    "typescript": "~5.9.3",
    "vite": "npm:rolldown-vite@latest",
    "vite-plugin-run": "^0.6.1",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.2",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "stylelint-order": "^8.1.1",
    "stylelint-selector-bem-pattern": {
      "stylelint": "$stylelint"
    }
  }
}