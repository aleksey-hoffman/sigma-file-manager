{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue", "src-shared/**/*.json", "packages/api/package.json"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "resolveJsonModule": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "paths": {
      "@shared/*": ["./src-shared/*"],
      "@/*": ["./src/*"],
      "@sigma-file-manager/api": ["./packages/api/index.d.ts"]
    }
  }
}
